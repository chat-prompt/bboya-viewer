---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'OpenClaw 플랫폼팀 전략 워크스페이스' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | OpenClaw 플랫폼팀</title>
  <meta name="description" content={description} />
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">
        <span class="logo-icon">🚀</span>
        <span>OpenClaw 플랫폼팀</span>
      </a>
      <nav class="site-nav">
        <a href="/docs">전략 문서</a>
        <a href="/meetings">회의록</a>
        <a href="/insights">인사이트</a>
        <a href="/weekly">주간</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>🚀 OpenClaw 플랫폼팀 — 오픈클로 = 지피터스</p>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
