---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allDocs = await getCollection('openclaw-platform');

// Group by subfolder
const topLevel: typeof allDocs = [];
const meetings: typeof allDocs = [];
const duckhuArchive: typeof allDocs = [];
const reports: typeof allDocs = [];

for (const doc of allDocs) {
  if (doc.slug.startsWith('meetings/')) meetings.push(doc);
  else if (doc.slug.startsWith('duckhu-archive/')) duckhuArchive.push(doc);
  else if (doc.slug.startsWith('reports/')) reports.push(doc);
  else if (doc.slug.toLowerCase() !== 'readme') topLevel.push(doc);
}

topLevel.sort((a, b) => a.slug.localeCompare(b.slug));
---

<BaseLayout title="openclaw-platform">
  <div class="list-page">
    <header class="list-header">
      <h1>🤖 openclaw-platform</h1>
      <p>플랫폼 전략, 채널 설계, 봇 코칭 모델, KPI — 오픈클로 실사용자 니즈 검증 프로젝트</p>
    </header>

    <h2 class="section-title">📝 전략 문서 <span class="count">{topLevel.length}편</span></h2>
    <div class="list-grid">
      {topLevel.map((doc) => (
        <a href={`/openclaw-platform/${doc.slug}`} class="list-card">
          <h3 class="card-title">{doc.data.title}</h3>
          {doc.data.date && <span class="card-date">{doc.data.date}</span>}
          {doc.data.description && <p class="card-desc">{doc.data.description}</p>}
        </a>
      ))}
    </div>

    <h2 class="section-title">📂 하위 폴더</h2>
    <div class="folder-grid">
      <a href="/openclaw-platform/meetings" class="folder-card">
        <span class="folder-icon">🗓️</span>
        <div>
          <h3>회의록</h3>
          <p>{meetings.length}편 — 태현님·닿·소연·소파 회의 기록</p>
        </div>
      </a>
      <a href="/openclaw-platform/duckhu-archive" class="folder-card">
        <span class="folder-icon">🔍</span>
        <div>
          <h3>덕후방 아카이브</h3>
          <p>{duckhuArchive.length}편 — 일일/주간 아카이브, 인사이트, 패턴 분석</p>
        </div>
      </a>
      <a href="/openclaw-platform/reports" class="folder-card">
        <span class="folder-icon">📊</span>
        <div>
          <h3>보고서</h3>
          <p>{reports.length}편 — 웨비나 성과, Q&A, 운영 모니터링</p>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .list-page { max-width: 800px; margin: 0 auto; padding: 0 24px 80px; }
  .list-header { text-align: center; padding: 60px 0 24px; }
  .list-header h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; font-family: var(--font-mono); }
  .list-header p { font-size: 16px; color: var(--text-secondary); }

  .section-title {
    font-size: 17px; font-weight: 700; margin: 32px 0 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .count {
    font-size: 12px; font-weight: 600; color: var(--accent);
    background: var(--accent-bg); padding: 2px 8px; border-radius: 10px;
  }

  .list-grid { display: flex; flex-direction: column; gap: 10px; }
  .list-card {
    display: block; padding: 16px 20px;
    background: var(--bg-card); border: 1px solid var(--border-card);
    border-radius: 12px; text-decoration: none; transition: all 0.2s;
  }
  .list-card:hover { border-color: var(--accent); transform: translateY(-1px); }
  .card-title { font-size: 16px; font-weight: 700; color: var(--text-primary); }
  .card-date { font-size: 12px; color: var(--text-muted); margin-top: 2px; display: inline-block; }
  .card-desc { font-size: 13px; color: var(--text-secondary); margin-top: 4px; line-height: 1.5; }

  .folder-grid { display: flex; flex-direction: column; gap: 10px; }
  .folder-card {
    display: flex; align-items: center; gap: 16px;
    padding: 20px 24px;
    background: var(--bg-card); border: 1px solid var(--border-card);
    border-left: 4px solid var(--accent);
    border-radius: 12px; text-decoration: none; transition: all 0.2s;
  }
  .folder-card:hover { border-color: var(--accent); transform: translateY(-1px); box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  .folder-icon { font-size: 32px; flex-shrink: 0; }
  .folder-card h3 { font-size: 16px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
  .folder-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.4; }
</style>
