---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const docs = (await getCollection('overview')).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---
<BaseLayout title="전체 그림">
  <div class="list-page">
    <header class="list-header"><h1>🏠 전체 그림</h1><p>미션, 팀 구성, 유입 퍼널, KPI</p></header>
    <div class="list-grid">
      {docs.map((doc) => (
        <a href={`/overview/${doc.slug}`} class="list-card">
          <div class="card-header">
            {doc.data.publishedAt && <span class="card-date">{doc.data.publishedAt}</span>}
          </div>
          <h2 class="card-title">{doc.data.title}</h2>
          {doc.data.description && <p class="card-desc">{doc.data.description}</p>}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
<style>
  .list-page { max-width: 800px; margin: 0 auto; padding: 0 24px 80px; }
  .list-header { text-align: center; padding: 60px 0 40px; }
  .list-header h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; }
  .list-header p { font-size: 16px; color: var(--text-secondary); }
  .list-grid { display: flex; flex-direction: column; gap: 12px; }
  .list-card { display: block; padding: 20px 24px; background: var(--bg-card); border: 1px solid var(--border-card); border-radius: 12px; text-decoration: none; transition: all 0.2s; }
  .list-card:hover { border-color: var(--accent); transform: translateY(-1px); }
  .card-header { margin-bottom: 8px; }
  .card-date { font-size: 12px; color: var(--text-muted); }
  .card-title { font-size: 18px; font-weight: 700; color: var(--text-primary); }
  .card-desc { font-size: 13px; color: var(--text-secondary); margin-top: 6px; line-height: 1.5; }
</style>
