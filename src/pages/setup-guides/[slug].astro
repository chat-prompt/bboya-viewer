---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TokenGate from '../../components/TokenGate.astro';
import ProtectedContent from '../../components/ProtectedContent.astro';

export async function getStaticPaths() {
  const guides = await getCollection('setup-guides');
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await guide.render();
const hasToken = !!guide.data.token;

const guides = (await getCollection('setup-guides')).sort((a, b) => a.data.episode - b.data.episode);
const currentIndex = guides.findIndex((g) => g.slug === guide.slug);
const prevGuide = currentIndex > 0 ? guides[currentIndex - 1] : null;
const nextGuide = currentIndex < guides.length - 1 ? guides[currentIndex + 1] : null;
---

<BaseLayout title={guide.data.title} description={guide.data.description} ogImage={guide.data.cover}>
  <div class="back-to-list top">
    <a href="/setup-guides">← 가이드 목록</a>
  </div>

  <TokenGate token={guide.data.token} slug={guide.slug} collection="setup-guide" />

  <ProtectedContent hasToken={hasToken}>
    <article>
      <header class="article-header">
        <span class="series-badge">🔧 실전 가이드 #{guide.data.episode}</span>
        <h1>{guide.data.title}</h1>
        <div class="meta">
          {guide.data.publishedAt && (
            <span>{guide.data.publishedAt}</span>
          )}
        </div>
      </header>

      <div class="article-body">
        <Content />
      </div>
    </article>

    {(prevGuide || nextGuide) && (
      <nav class="article-nav">
        {prevGuide && (
          <a href={`/setup-guides/${prevGuide.slug}`} class="prev">
            <span class="nav-label">← 이전 가이드</span>
            <span class="nav-title">#{prevGuide.data.episode} {prevGuide.data.title}</span>
          </a>
        )}
        {nextGuide && (
          <a href={`/setup-guides/${nextGuide.slug}`} class="next">
            <span class="nav-label">다음 가이드 →</span>
            <span class="nav-title">#{nextGuide.data.episode} {nextGuide.data.title}</span>
          </a>
        )}
      </nav>
    )}
  </ProtectedContent>
</BaseLayout>
